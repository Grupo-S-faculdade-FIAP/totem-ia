# Configuração do TOTEM IA - Fase 2

# ============================================================================
# 🐛 MODO DEBUG - DESENVOLVIMENTO
# ============================================================================
# ⚠️  NUNCA ATIVAR EM PRODUÇÃO!
# true  = Ativa botão "Modo Debug Confirmar" na interface
# false = Desativa (ambiente de produção)
MODO_DEBUG=false

# ============================================================================
# OpenAI API
# ============================================================================
OPENAI_API_KEY=sk-xxxxxxxxxxxx

# ============================================================================
# HuggingFace Token
# ============================================================================
HUGGINGFACE_TOKEN=hf_xxxxxxxxxxxx

# ============================================================================
# ESP32 TOTEM SERVER - API EXTERNA (Render.com)
# ============================================================================

# URL da API do ESP32 (Render.com ou local)
# Producao: https://esp32-totem-server.onrender.com
# Local: http://localhost:5001
ESP32_API_URL=https://esp32-totem-server.onrender.com

# Chave única do dispositivo ESP32
ESP32_DEVICE_KEY=esp32-totem-vnVElI_NNq8

# JWT Secret (deve ser o mesmo da API ESP32)
JWT_SECRET=H2osYqbtJJv3xJRzV3-g0Bt0nmcTon_JdVateUGxyTU

# ============================================================================
# ESP32 - Validação Mecânica Local (Fallback)
# ============================================================================
ESP32_IP=192.168.1.101
ESP32_PORT=80
ESP32_TIMEOUT=5

# ============================================================================
# Flask
# ============================================================================
FLASK_HOST=0.0.0.0
FLASK_PORT=8000
FLASK_DEBUG=False

# ============================================================================
# Database
# ============================================================================
DATABASE_PATH=totem_data.db

# ============================================================================
# Ambiente
# ============================================================================
ENVIRONMENT=production
