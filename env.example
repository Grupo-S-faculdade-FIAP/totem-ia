# ============================================================================
# CONFIGURAÇÃO DO TOTEM IA
# ============================================================================
# Copie este arquivo para .env e atualize com seus valores
# Nunca commita o arquivo .env com senhas reais!
# ============================================================================

# ---- Modo Debug ----
# Ativar modo debug para testes (NUNCA em produção!)
MODO_DEBUG=False

# ---- Credenciais Admin ----
# Altere em produção com valores fortes!
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123

# ---- OpenAI (Opcional) ----
# OPENAI_API_KEY=sk-...

# ---- Banco de Dados (Opcional) ----
# DATABASE_URL=sqlite:///totem.db

# ---- Servidor ----
# FLASK_ENV=development
# FLASK_DEBUG=True
# SERVER_PORT=5003
# SERVER_HOST=0.0.0.0

