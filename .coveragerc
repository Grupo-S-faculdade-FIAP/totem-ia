[run]
# Configuração de cobertura de código
source = src
omit =
    */site-packages/*
    */venv/*
    */__pycache__/*
    */tests/*
    src/models_classifiers/*
    src/models_trainers/*

[report]
# Relatório de cobertura
exclude_lines =
    pragma: no cover
    def __repr__
    raise AssertionError
    raise NotImplementedError
    if __name__ == .__main__.:
    if TYPE_CHECKING:
    @abstractmethod
    @abc.abstractmethod
    def __str__

[html]
directory = htmlcov
